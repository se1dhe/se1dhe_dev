# API settings
VUE_APP_API_URL=http://localhost:8000
VUE_APP_WS_URL=ws://localhost:8000/ws

# Telegram settings
VUE_APP_TELEGRAM_BOT_USERNAME=your_bot_username
VUE_APP_TELEGRAM_BOT_TOKEN=your_bot_token

# Payment settings
VUE_APP_PAYMENT_GATEWAY_URL=your_payment_gateway_url
VUE_APP_PAYMENT_GATEWAY_KEY=your_payment_gateway_key

# Analytics
VUE_APP_GA_ID=your_google_analytics_id

# Feature flags
VUE_APP_ENABLE_WEBSOCKET=true
VUE_APP_ENABLE_TELEGRAM_AUTH=true 